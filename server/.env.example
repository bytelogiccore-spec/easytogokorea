# EasyToGoKorea API Server - Environment Variables
# Copy this file to .env and fill in your API keys.
# Get keys from: https://data.go.kr (공공데이터포털)

# Server
HOST=0.0.0.0
PORT=3000

# 공공데이터포털 서비스 키 (URL 인코딩된 키)
# 한국관광공사 TourAPI 4.0
KTO_TOUR_API_KEY=f337bf3a671e98b82ef5ce94bbbf70f9fe690579c5688c32495bd0f5d148bdb8

#국립해양조사원 개방 오픈API
