# EasyToGoKorea API Server - Environment Variables
# Copy this file to .env and fill in your API keys.
# Get keys from: https://data.go.kr (공공데이터포털)

# Server
HOST=0.0.0.0
PORT=3000

# 공공데이터포털 서비스 키 (URL 인코딩된 키)
# 한국관광공사 TourAPI 4.0
KTO_TOUR_API_KEY=YOUR_TOUR_API_KEY_HERE

# 기상청 단기예보 API
KMA_WEATHER_API_KEY=YOUR_WEATHER_API_KEY_HERE

# 에어코리아 대기질 API
AIRKOREA_API_KEY=YOUR_AIRKOREA_API_KEY_HERE

# 한국은행 경제통계 API
BOK_API_KEY=YOUR_BOK_API_KEY_HERE

# 서울시 OpenAPI
SEOUL_API_KEY=YOUR_SEOUL_API_KEY_HERE

# 응급의료 정보 API
EMERGENCY_API_KEY=YOUR_EMERGENCY_API_KEY_HERE
